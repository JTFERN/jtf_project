      <aliases enabled='yes' />
      <column caption='graph_drill' datatype='string' name='[Calculation_0217481788030976]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [Parameters].[Parameter 1]=1 then STR([color_numbers])&#13;&#10;ELSEIF  [Parameters].[Parameter 1]=2 then str([life])&#13;&#10;ELSEIF  [Parameters].[Parameter 1]=3 then str([power])&#13;&#10;ELSEIF  [Parameters].[Parameter 1]=4 then str([color])&#13;&#10;END' />
      </column>
      <column caption='color_Test' datatype='string' name='[Calculation_0217481792397314]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([color], &apos;Red&apos;) THEN &apos;Red&apos;&#13;&#10;&#13;&#10;// [Is Blue]&#13;&#10;ELSEIF  CONTAINS([color], &apos;Blue&apos;) THEN &apos;Blue&apos;&#13;&#10;&#13;&#10;// [Is Yellow]&#13;&#10;ELSEIF CONTAINS([color], &apos;Yellow&apos;) THEN &apos;Yellow&apos;&#13;&#10;&#13;&#10;// [Is Green]&#13;&#10;ELSEIF CONTAINS([color], &apos;Green&apos;) THEN &apos;Green&apos;&#13;&#10;&#13;&#10;// [Is Purple]&#13;&#10;ELSEIF CONTAINS([color], &apos;Purple&apos;) THEN &apos;Purple&apos;&#13;&#10;&#13;&#10;// [Is Black]&#13;&#10;ELSEIF CONTAINS([color], &apos;Black&apos;) THEN &apos;Black&apos;&#13;&#10;END' />
      </column>
      <column caption='1st' datatype='integer' name='[Calculation_0217481793941507]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [placement]=&apos;1st&apos;then 1 else 0 END' />
      </column>
